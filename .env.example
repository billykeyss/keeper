DATABASE_URL=postgres://fl:fl@localhost:5433/fishing_law
# Chat password gate (unset = chat open; the rest of the app is always public)
KEEPER_PASSWORD=
# Regulations chat — enabled only when BOTH ANTHROPIC_API_KEY and KEEPER_PASSWORD are set
ANTHROPIC_API_KEY=
# Optional model override for chat (defaults to claude-haiku-4-5)
CHAT_MODEL=claude-haiku-4-5
