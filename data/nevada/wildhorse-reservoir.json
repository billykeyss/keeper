  "sources": [
    { "key": "s_cr2516", "url": "https://www.ndow.org/wp-content/uploads/2025/09/24-A-CR-25-16-Fishing-Seasons-and-Regulations-for-January-1-2026-through-December-31-2027.pdf", "title": "State of Nevada Board of Wildlife Commissioners — CR 25-16: Fishing Seasons and Regulations, January 1, 2026 – December 31, 2027", "documentType": "pdf", "instrumentType": "commission_reg", "authorityLevel": "primary_regulatory", "authorityKey": "ndow", "retrievedDate": "2026-07-01", "quotedText": "Wildhorse Reservoir and all inlet and outlet streams including Penrod Creek up to the bridge below the Gold Creek Ranger Station: Season: Open year around. Exception: March 1 through June 30, catch and release fishing only for black bass. Limits — Daily: 5 trout, 1 black bass, 1 white bass hybrid (wiper) and 5 channel catfish. No limit on yellow perch (unlimited possession). Minimum size for black bass and white bass hybrids (wiper) is 15 inches total length. Possession: 10 trout, 2 black bass, 2 white bass hybrid (wiper) and 10 channel catfish. Hours: Any hour of the day or night." },
    { "key": "s_ndow_water", "url": "https://www.ndow.org/waters/wildhorse-reservoir/", "title": "Wildhorse Reservoir — Nevada Department of Wildlife", "documentType": "webpage", "instrumentType": "webpage", "authorityLevel": "primary_regulatory", "authorityKey": "ndow", "retrievedDate": "2026-07-02", "quotedText": "Coldwater game species include rainbow, brown, bowcutt (rainbow x cutthroat hybrid), and tiger trout (brown x brook trout hybrid). Warmwater game species consists of smallmouth bass, largemouth bass, channel catfish, wipers (white bass x striper hybrid), and yellow perch. Rainbow trout, brown trout, tiger trout and wiper were stocked this spring." },
    { "key": "s_ndow_apply_buy", "url": "https://www.ndow.org/apply-buy/fishing/", "title": "Apply & Buy — Nevada Fishing Licenses — NDOW", "documentType": "webpage", "instrumentType": "webpage", "authorityLevel": "primary_regulatory", "authorityKey": "ndow", "retrievedDate": "2026-07-01", "quotedText": "Anyone 12 years of age or older is required to have a fishing license in their possession while in the field." },
